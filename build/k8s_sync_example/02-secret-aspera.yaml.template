apiVersion: v1
kind: Secret
metadata:
  name: aspera-credentials
  namespace: aspera  # Created in: 01-namespace.yaml
type: Opaque
stringData: # secrets in clear, else use `data` and base64 encode
  aspera-xfer-password: "your-password-here"
  aws-access-key-id: "your-aws-access-key"
  aws-secret-access-key: "your-aws-secret-key"
