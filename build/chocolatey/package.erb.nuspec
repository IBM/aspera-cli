<?xml version="1.0"?>
<package>
  <metadata>
    <id>%=choco_package%</id>
    <version>%=nuget_version_build%</version>
    <title>Aspera CLI</title>
    <authors>Laurent Martin</authors>
    <readme>README.md</readme>
    <projectUrl>https://github.com/you/your-gem-name</projectUrl>
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Installs Ruby, VC++ Redistributable, then installs the aspera-cli gem and configures transfer daemon.</description>
    <tags>ascli aspera cli ascp ibm</tags>
    <dependencies>
      <dependency id="ruby" version="[3.2.0,)" />
      <dependency id="vcredist140" version="[14.0.0,)" />
    </dependencies>
  </metadata>
</package>
