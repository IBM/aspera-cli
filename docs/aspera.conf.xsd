              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="session_progress_interval" type="xs:string" default="1" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Session Progress Interval (seconds). Type: uint64. The frequency at which an Aspera node logs transfer session information, up to 65535 seconds.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="file_events" default="true" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Show File Events. Type: boolean (true|false). Setting this value to true enables the logging of complete file paths and file names. Performance may be impacted when transferring datasets containing thousands of files. Also see Files Per Session for setting a threshold for the number of files to log per session.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="file_progress" default="true" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Show File Progress. Type: boolean (true|false). Setting this value to true will log file status such as bytes transferred, at a given interval.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="file_errors" default="true" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false).</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="file_progress_interval" type="xs:string" default="1" minOccurs="1">
              <xs:annotation>
                <xs:documentation>File Progress Interval (seconds). Type: uint64. The frequency at which an Aspera node logs file transfer information, up to 65535 seconds. The default setting of 1 logs information every second.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="files_per_session" type="xs:string" default="0" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint64. The value set will be the cut-off point for file names logged in a given session. For instance, if the value is set to 50, the first 50 file names will be recorded for any session. The session will still record the number of files transferred along with the number of files completed, failed or skipped. The default setting of 0 logs all file names for a given session.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="ignore_empty_files" default="false" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false). Setting this to true will block the logging of zero-byte files.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="ignore_skipped_files" default="false" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false).</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="ignore_no_transfer_files" default="false" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Ignore No-transfer Files. Type: boolean (true|false). Setting this to true will block the logging of files that have not been transferred because they exist at the destination at the time the transfer started.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="rate_events" default="true" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Show Rate Events. Type: boolean (true|false). Setting this to true will log changes made to the Target Rate, Minimum Rate, and Transfer Policy by any user or Aspera node administrator during a transfer.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="node_registration" default="true" minOccurs="1">
