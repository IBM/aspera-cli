                  <xs:element name="tightness_out" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>trunk_tightness_out. Type: float.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="qb_over_qmax" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>trunk_qb_over_qmax. Type: float.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                </xs:all>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="central_server" minOccurs="1">
        <xs:complexType>
          <xs:all>
            <xs:element name="address" type="xs:string" default="127.0.0.1" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: string. This is the network interface address on which the transfer server listens. The default value 127.0.0.1 enables the transfer server to accept transfer requests from the local computer. Setting the value to 0.0.0.0 allows the Aspera transfer server to accept transfer requests on all network interfaces for this node. Alternatively, a specific network interface address may be specified.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="port" type="xs:string" default="40001" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32. Range: 1-65535 The port at which the transfer server will accept transfer requests. Valid port numbers range between 1 and 65535.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="backlog" type="xs:string" default="200" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: int32.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="schema_validation" default="enable" minOccurs="1">
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="disable"/>
                  <xs:enumeration value="enable"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="raw_options" default="disable" minOccurs="1">
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="disable"/>
                  <xs:enumeration value="enable"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="mgmt_backlog" type="xs:string" default="200" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: int32.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="mgmt_port" type="xs:string" default="0" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="transfer_list_path" type="xs:string" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: string.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="persistent_store" default="enable" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Persistent Storage. Store transfer history locally</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="disable"/>
                  <xs:enumeration value="enable"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="persistent_store_path" type="xs:string" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Persistent Storage Path. Type: string. Path to store the local transfer history database. If it is currently a directory, create file with default name central-store.db Otherwise use the file name as is.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="persistent_store_max_age" type="xs:string" default="86400" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Maximum Age (seconds). Type: uint32. Preset display values: Unlimited. Time to retain local transfer history data</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="persistent_store_on_error" default="ignore" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Exit Central on Storage Error. Should we terminate the Central server if an error writing to the local transfer history database occurs?</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="ignore"/>
                  <xs:enumeration value="exit"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="event_buffer_capacity" type="xs:string" default="1000" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="event_buffer_overrun" default="block" minOccurs="1">
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="drop"/>
                  <xs:enumeration value="block"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="compact_on_startup" default="enable" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Compact Database on Startup. Compact the local transfer history database on startup (this may take a while).</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="disable"/>
                  <xs:enumeration value="enable"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="files_per_session" type="xs:string" default="1000000" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint64. The value set will be the cut-off point for file names logged in a given session. For instance, if the value is set to 50, the first 50 file names will be recorded for any session. The session will still record the number of files transferred along with the number of files completed, failed or skipped. The setting of 0 logs all file names for a given session.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="file_errors" default="true" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false).</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="ignore_empty_files" default="true" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false). Setting this to true will block the logging of zero-byte files.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="ignore_skipped_files" default="true" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false).</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="ignore_no_transfer_files" default="true" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Ignore No-transfer Files. Type: boolean (true|false). Setting this to true will block the logging of files that have not been transferred because they exist at the destination at the time the transfer started.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="db_synchronous" default="off" minOccurs="1">
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="off"/>
                  <xs:enumeration value="normal"/>
                  <xs:enumeration value="full"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="db_journal" default="wal" minOccurs="1">
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="wal"/>
                  <xs:enumeration value="delete"/>
                  <xs:enumeration value="truncate"/>
                  <xs:enumeration value="persist"/>
                  <xs:enumeration value="memory"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="validation_timeout" type="xs:string" default="300" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Post-Transfer Validation Timeout (seconds). Type: uint32. The amount of time, in seconds, that Central will wait before considering a validator is down.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:all>
        </xs:complexType>
      </xs:element>
      <xs:element name="http_server" minOccurs="1">
        <xs:complexType>
          <xs:all>
            <xs:element name="cert_file" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Type: string. The absolute path to an SSL certificate file. If left blank, the default certificate file that came with your Aspera Enterprise Server will be used.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="key_file" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Type: string. The absolute path to an SSL key file. If left blank, the default key file that came with your Aspera Enterprise Server will be used.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="bind_address" type="xs:string" default="0.0.0.0" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: string. This is the network interface address on which the HTTP Fallback Server listens. The default value 0.0.0.0 allows the Aspera HTTP Fallback Server to accept transfer requests on all network interfaces for this node. Alternatively, a specific network interface address may be specified.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="mgmt_address" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Type: string.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="restartable_transfers" default="true" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false). Setting this to true allows interrupted transfers to resume at the point of interruption.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="session_activity_timeout" type="xs:string" default="20" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint64. Setting this to 0 means the HTTP Fallback Server will never timeout due to lack of communication from the client. Any value greater than 0 sets the amount of time, in seconds, that the HTTP Fallback Server will wait before canceling the transfer.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="http_port" type="xs:string" default="8080" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32. Range: 1-65535 The port on which the HTTP server listens. Valid port numbers range between 1 and 65535.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="https_port" type="xs:string" default="8443" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32. Range: 1-65535 The port on which the HTTPS server listens. Valid port numbers range between 1 and 65535.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="enable_http" default="false" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false). Enables the Aspera HTTP Fallback Server that allows failed UDP transfers to continue over HTTP.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="enable_https" default="false" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false). Enables the secure Aspera HTTPS Fallback Server that allows failed UDP transfers to continue over HTTPS.</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="persistent_connection" default="false" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: boolean (true|false).</xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:string">
                  <xs:enumeration value="true"/>
                  <xs:enumeration value="false"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="listen_backlog" type="xs:string" default="20" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: int32. Size of backlog queue for incoming HTTP or HTTPS connections. This setting applies separately for HTTP and HTTPS connections if both are active.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:all>
        </xs:complexType>
      </xs:element>
      <xs:element name="database" minOccurs="1">
        <xs:complexType>
          <xs:all>
            <xs:element name="adapter" type="xs:string" default="mysql" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: string.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="server" type="xs:string" default="127.0.0.1" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Host IP. Type: string. The transfer server can optionally log transfer information to a database server. Enter the IP address of the database server (or the IP address of the Aspera Console server).</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="port" type="xs:string" default="4406" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32. Range: 1-65535 The default value for an Aspera Console installation is 4406. Valid port numbers range between 1 and 65535.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="user" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Type: string. User login for the database server.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="password" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Type: string. Password to the database</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="database_name" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Type: string. Name of the database used to store Aspera transfer data.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="threads" type="xs:string" default="1" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32. The number of parallel connections used for database logging. A higher value may be useful when a large number of files are being transferred within a short timeframe.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="exit_on_database_error" default="false" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Stop Transfers on Database Error. Type: boolean (true|false). Quits all ongoing transfers and no new transfers are permitted when a database error prevents data from being written to the database. Set this to true if all transfers must be logged by your organization.</xs:documentation>
