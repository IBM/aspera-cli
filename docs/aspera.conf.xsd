            </xs:element>
            <xs:element name="max_running_ascp_timeout" type="xs:string" default="1m" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: time string (e.g. 01:00:00).</xs:documentation>
              </xs:annotation>
            </xs:element>
