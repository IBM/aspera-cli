<?xml version="1.0" encoding="UTF-8"?>
<xs:schema
    xmlns:xs="http://www.w3.org/2001/XMLSchema"
    elementFormDefault="qualified"
    version="1.0">
<xs:element name="conf">
  <xs:annotation>
    <xs:documentation>Root configuration element for Aspera transfer software. Build version 4.4.7.2228.</xs:documentation>
  </xs:annotation>
  <xs:complexType>
    <xs:all>
      <xs:element name="default" minOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="user_value" type="xs:string" default="0" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: int64.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="name" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Type: string.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="group" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Type: string.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="group_ownership" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Specify group ownership. Type: string. Sets the group ownership to the specified group name. Entering a - (dash) will ignore setting group ownership. Setting is used by files and folders created with node api.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="connection_timeout_sec" type="xs:string" default="20" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="session_timeout_sec" type="xs:string" default="60" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="ssh_startup_timeout_sec" type="xs:string" default="0" minOccurs="1">
              <xs:annotation>
                <xs:documentation>Type: uint32.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="authorization" minOccurs="1">
              <xs:complexType>
                <xs:all>
                  <xs:element name="transfer" minOccurs="1">
                    <xs:complexType>
                      <xs:all>
                        <xs:element name="in" minOccurs="1">
                          <xs:complexType>
                            <xs:all>
                              <xs:element name="value" default="allow" minOccurs="1">
                                <xs:annotation>
                                  <xs:documentation>Incoming Transfers. The default setting of allow allows users to transfer to this computer. Setting this to deny will prevent transfers to this computer. When set to token, only transfers initiated with valid tokens will be allowed to transfer to this computer. Token-based transfers are typically employed by web applications such as Faspex and require a Token Encryption Key.</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                  <xs:restriction base="xs:string">
                                    <xs:enumeration value="allow"/>
                                    <xs:enumeration value="deny"/>
                                    <xs:enumeration value="token"/>
                                  </xs:restriction>
                                </xs:simpleType>
                              </xs:element>
                              <xs:element name="external_provider" minOccurs="1">
                                <xs:complexType>
                                  <xs:all>
                                    <xs:element name="url" type="xs:string" minOccurs="0">
                                      <xs:annotation>
                                        <xs:documentation>Incoming External Provider URL. Type: string. The value entered should be the URL of the external authorization provider for incoming transfers. The default empty setting disables external authorization. Aspera servers can be configured to check with an external authorization provider. This SOAP authorization mechanism can be useful to organizations requiring custom authorization rules.</xs:documentation>
                                      </xs:annotation>
                                    </xs:element>
                                    <xs:element name="soap_action" type="xs:string" minOccurs="0">
                                      <xs:annotation>
                                        <xs:documentation>Incoming External Provider SOAP Action. Type: string. The SOAP action required by the external authorization provider for incoming transfers. Required if External Authorization is enabled.</xs:documentation>
                                      </xs:annotation>
                                    </xs:element>
                                  </xs:all>
                                </xs:complexType>
                              </xs:element>
                            </xs:all>
                          </xs:complexType>
                        </xs:element>
                        <xs:element name="out" minOccurs="1">
                          <xs:complexType>
                            <xs:all>
                              <xs:element name="value" default="allow" minOccurs="1">
                                <xs:annotation>
                                  <xs:documentation>Outgoing Transfers. The default setting of allow allows users to transfer from this computer. Setting this to deny will prevent transfers from this computer. When set to require token, only transfers initiated with valid tokens will be allowed to transfer from this computer. Token-based transfers are typically employed by web applications such as Faspex and require a Token Encryption Key.</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                  <xs:restriction base="xs:string">
                                    <xs:enumeration value="allow"/>
                                    <xs:enumeration value="deny"/>
                                    <xs:enumeration value="token"/>
                                  </xs:restriction>
                                </xs:simpleType>
                              </xs:element>
                              <xs:element name="external_provider" minOccurs="1">
                                <xs:complexType>
                                  <xs:all>
                                    <xs:element name="url" type="xs:string" minOccurs="0">
                                      <xs:annotation>
                                        <xs:documentation>Outgoing External Provider URL. Type: string. The value entered should be the URL of the external authorization provider for outgoing transfers. The default empty setting disables external authorization. Aspera servers can be configured to check with an external authorization provider. This SOAP authorization mechanism can be useful to organizations requiring custom authorization rules.</xs:documentation>
                                      </xs:annotation>
                                    </xs:element>
                                    <xs:element name="soap_action" type="xs:string" minOccurs="0">
                                      <xs:annotation>
                                        <xs:documentation>Outgoing External Provider SOAP Action. Type: string. The SOAP action required by the external authorization provider for outgoing transfers. Required if External Authorization is enabled.</xs:documentation>
                                      </xs:annotation>
                                    </xs:element>
                                  </xs:all>
                                </xs:complexType>
                              </xs:element>
                            </xs:all>
                          </xs:complexType>
                        </xs:element>
                      </xs:all>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="token" minOccurs="1">
                    <xs:complexType>
                      <xs:all>
                        <xs:element name="encryption_type" default="aes-128" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Token Encryption Cipher. The cipher used to generate encrypted authorization tokens (not used to encrypt transfer data). Only used with token-based authorization (primarily used with web-based transfer applications).</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="aes-128"/>
                              <xs:enumeration value="aes-192"/>
                              <xs:enumeration value="aes-256"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="encryption_key" type="xs:string" minOccurs="0">
                          <xs:annotation>
                            <xs:documentation>Token Encryption Key. Type: string. The secret passphrase used to generate encrypted authorization tokens (not used to encrypt transfer data). Only used with token-based authorization (primarily used with web-based transfer applications).</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="key_file" type="xs:string" minOccurs="0">
                          <xs:annotation>
                            <xs:documentation>token_encryption_keyfile. Type: string.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="life_seconds" type="xs:string" default="86400" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Token Life (seconds). Type: uint32. The time before authorization tokens expire. Only used with token-based authorization (primarily used with web-based transfer applications).</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="filename_hash" default="sha1" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Token filename hash. Which algorithm should filenames inside transfer tokens be hashed with.</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="sha1"/>
                              <xs:enumeration value="md5"/>
                              <xs:enumeration value="lzw"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="dynamic_key" default="false" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>token_dynamic_key. Type: boolean (true|false).</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                      </xs:all>
                    </xs:complexType>
                  </xs:element>
                </xs:all>
              </xs:complexType>
            </xs:element>
            <xs:element name="transfer" minOccurs="1">
              <xs:complexType>
                <xs:all>
                  <xs:element name="in" minOccurs="1">
                    <xs:complexType>
                      <xs:all>
                        <xs:element name="bandwidth" minOccurs="1">
                          <xs:complexType>
                            <xs:all>
                              <xs:element name="aggregate" minOccurs="1">
                                <xs:complexType>
                                  <xs:all>
                                    <xs:element name="trunk_id" type="xs:string" default="Disabled" minOccurs="1">
                                      <xs:annotation>
                                        <xs:documentation>Incoming Vlink ID. Type: uint32. Preset display values: Disabled. The value sets the Vlink ID for incoming transfers. Vlinks are a mechanism to define aggregate transfer policies. The default setting of 0 disables this Vlink. One Vlink (the virtual equivalent of a network trunk) represents a bandwidth allowance that may be allocated to a node, group, or user. Vlink IDs are defined in each Vlink created in the Aspera Console or GUI. The Vlink ID is a unique numeric identifier.</xs:documentation>
                                      </xs:annotation>
                                    </xs:element>
                                  </xs:all>
                                </xs:complexType>
                              </xs:element>
                              <xs:element name="flow" minOccurs="1">
                                <xs:complexType>
                                  <xs:all>
                                    <xs:element name="target_rate" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="cap" type="xs:string" default="Unlimited" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Target Rate Cap (Kbps). Type: uint64. Preset display values: Unlimited. The Target Rate Cap for incoming transfers. This is the maximum target rate that a transfer can request, in kilobits per second. No transfer may be adjusted above this setting, at any time. The default setting of Unlimited signifies no Target Rate Cap. Clients requesting transfers with initial rates above the Target Rate Cap will be slowed down.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="default" type="xs:string" default="10000" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Target Rate Default (Kbps). Type: uint64. This value represents the initial transfer rate for incoming transfers, in kilobits per second. Users may be able to modify this rate in real time as allowed by the software in use.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="lock" default="false" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Target Rate Lock. Type: boolean (true|false). After an incoming transfer is started, its target rate may be modified in real time. The default setting of false gives users the ability to adjust the transfer rate. A setting of true prevents real-time modification of the transfer rate.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="min_rate" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="cap" type="xs:string" default="0" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Minimum Rate Cap (Kbps). Type: uint64. Preset display values: Unlimited. The Minimum Rate Cap for incoming transfers. This is the highest Minimum Rate that a transfer can request, in kilobits per second. The Minimum Rate is the level beyond which a transfer will not slow down, despite network congestion or availability. The default value of Unlimited effectively turns off the Minimum Rate Cap.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="default" type="xs:string" default="0" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Minimum Rate Default (Kbps). Type: uint64. This value represents the initial minimum rate for incoming transfers, in kilobits per second. Users may be able to modify this rate in real time as allowed by the software in use. This setting is not relevant to transfers with a Policy of Fixed.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="lock" default="true" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Minimum Rate Lock. Type: boolean (true|false). After an incoming transfer is started, its minimum rate may be modified in real time. The default setting of false gives users the ability to adjust the transfer's minimum rate. A setting of true prevents real-time modification of the transfer rate. This setting is not relevant to transfers with a Policy of Fixed.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="policy" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="default" default="fair" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Bandwidth Policy Default. The value chosen sets the default Bandwidth Policy for incoming transfers. Aspera transfers use fixed, high, fair and low policies to accommodate network-sharing requirements.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="fixed"/>
                                                <xs:enumeration value="high"/>
                                                <xs:enumeration value="fair"/>
                                                <xs:enumeration value="regular"/>
                                                <xs:enumeration value="low"/>
                                                <xs:enumeration value="trickle"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="lock" default="false" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Bandwidth Policy Lock. Type: boolean (true|false). After an incoming transfer is started, its Policy may be modified in real time. The default setting of false gives users the ability to adjust the transfer's Policy. A setting of true prevents real-time modification of the Policy.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="allowed" default="any" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Bandwidth Policy Allowed. The value chosen sets the allowed Bandwidth Policy for incoming transfers. Aspera transfers use fixed, high, fair and low policies to accommodate network-sharing requirements. When set to any, the server will not deny any transfer based on policy setting. When set to high, transfers with a Policy of high and less aggressive transfer policies (e.g. fair or low) will be permitted. Fixed transfers will be denied. When set to low, only transfers with a Bandwidth Policy of low will be allowed.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="any"/>
                                                <xs:enumeration value="high"/>
                                                <xs:enumeration value="fair"/>
                                                <xs:enumeration value="regular"/>
                                                <xs:enumeration value="low"/>
                                                <xs:enumeration value="trickle"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="priority" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="cap" default="high" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_in_bandwidth_flow_priority_cap.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="high"/>
                                                <xs:enumeration value="normal"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="default" default="normal" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_in_bandwidth_flow_priority_default.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="high"/>
                                                <xs:enumeration value="normal"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="lock" default="false" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_in_bandwidth_flow_priority_lock. Type: boolean (true|false).</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="aggressiveness" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="cap" type="xs:string" default="0" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_in_bandwidth_flow_aggressiveness_cap. Type: float.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="default" type="xs:string" default="0" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_in_bandwidth_flow_aggressiveness_default. Type: float.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="network_rc" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="module" default="delay" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Rate Control Module. When specified in a client configuration, the value chosen will override the server configuration when the following two conditions are met: 1) the client is receiving and 2) the client configuration specifies a non-default module (eg. delay-odp or delay-adv).</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="delay"/>
                                                <xs:enumeration value="delay-odp"/>
                                                <xs:enumeration value="delay-adv"/>
                                                <xs:enumeration value="delay-laq"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="tcp_friendly" default="false" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_in_bandwidth_flow_network_rc_tcp_friendly. Type: boolean (true|false).</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="predictor" default="unset" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Traffic RTT Predictor. The predictor is designed to compensate for feedback signal delay due to RTT measurement itself. Numerical prediction methods include none|alphabeta|bezier|ets|fd31, none is the default.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="unset"/>
                                                <xs:enumeration value="none"/>
                                                <xs:enumeration value="alphabeta"/>
                                                <xs:enumeration value="fd31"/>
                                                <xs:enumeration value="bezier"/>
                                                <xs:enumeration value="ets"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="predictor_range" type="xs:string" default="2" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Rate Control Predictor Range. Type: float. The range of prediction, as a factor of the current sRTT. For example, the default value is 2.0, which means the predictor estimates the instantaneous network RTT that is 2.0*sRTT in the future. A higher value makes the rate-controller more sensitive to RTT changes, but also more vulnerable to RTT noise.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="predictor_limit_range" type="xs:string" default="3" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Rate Control Predictor Limit Range. Type: float. A limit function parameter that prevents the predictor from overpredicting. predictor_range &lt; prediction_limit_range. The default value is 3.0.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="target_queue" default="unset" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Incoming Rate Control Target Queue. Available options are static|dynamic. Static is the default target queueing scheme and is based on estimated bandwidth. Dynamic is a target queueing scheme based on estimated RTT noise level and propagation delay. Dynamic mode is designed to work with the RTT predictor so that the rate controller can reach equilibrium quickly.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="unset"/>
                                                <xs:enumeration value="static"/>
                                                <xs:enumeration value="dynamic"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                  </xs:all>
                                </xs:complexType>
                              </xs:element>
                            </xs:all>
                          </xs:complexType>
                        </xs:element>
                      </xs:all>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="out" minOccurs="1">
                    <xs:complexType>
                      <xs:all>
                        <xs:element name="bandwidth" minOccurs="1">
                          <xs:complexType>
                            <xs:all>
                              <xs:element name="aggregate" minOccurs="1">
                                <xs:complexType>
                                  <xs:all>
                                    <xs:element name="trunk_id" type="xs:string" default="Disabled" minOccurs="1">
                                      <xs:annotation>
                                        <xs:documentation>Outgoing Vlink ID. Type: uint32. Preset display values: Disabled. The value sets the Vlink ID for outgoing transfers. Vlinks are a mechanism to define aggregate transfer policies. The default setting of 0 disables Vlinks. One Vlink is the virtual equivalent of a network trunk and represents a bandwidth allowance that may be allocated to a node, group, or user. Vlink IDs are defined in each Vlink created in the Aspera Console or GUI. The Vlink ID is a unique numeric identifier.</xs:documentation>
                                      </xs:annotation>
                                    </xs:element>
                                  </xs:all>
                                </xs:complexType>
                              </xs:element>
                              <xs:element name="flow" minOccurs="1">
                                <xs:complexType>
                                  <xs:all>
                                    <xs:element name="target_rate" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="cap" type="xs:string" default="Unlimited" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Target Rate Cap (Kbps). Type: uint64. Preset display values: Unlimited. The Target Rate Cap for outgoing transfers. This is the maximum target rate that a transfer can request, in kilobits per second. No transfer may be adjusted above this setting, at any time. The default setting of Unlimited signifies no Target Rate Cap. Clients requesting transfers with initial rates above the Target Rate Cap will be slowed down.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="default" type="xs:string" default="10000" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Target Rate Default (Kbps). Type: uint64. This value represents the initial rate for outgoing transfers, in kilobits per second. Users may be able to modify this rate in real time as allowed by the software in use.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="lock" default="false" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Target Rate Lock. Type: boolean (true|false). After an outgoing transfer is started, its target rate may be modified in real time. The default setting of false gives users the ability to adjust the transfer rate. A setting of true prevents real-time modification of the transfer rate.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="min_rate" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="cap" type="xs:string" default="0" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Minimum Rate Cap (Kbps). Type: uint64. Preset display values: Unlimited. The Minimum Rate Cap for outgoing transfers. This is the highest Minimum Rate that a transfer can request, in kilobits per second. The Minimum Rate is the level beyond which a transfer will not slow down, despite network congestion or availability. The default value of Unlimited effectively turns off the Minimum Rate Cap.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="default" type="xs:string" default="0" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Minimum Rate Default (Kbps). Type: uint64. This value represents the initial minimum rate for outgoing transfers, in kilobits per second. Users may be able to modify this rate in real time as allowed by the software in use. This setting is not relevant to transfers with a Policy of Fixed.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="lock" default="true" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Minimum Rate Lock. Type: boolean (true|false). After an outgoing transfer is started, its minimum rate may be modified in real time. The default setting of false gives users the ability to adjust the transfer's minimum rate. A setting of true prevents real-time modification of the transfer rate. This setting is not relevant to transfers with a Policy of Fixed.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="policy" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="default" default="fair" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Bandwidth Policy Default. The value chosen sets the default Bandwidth Policy for outgoing transfers. Aspera transfers use fixed, high, fair and low policies to accommodate network-sharing requirements.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="fixed"/>
                                                <xs:enumeration value="high"/>
                                                <xs:enumeration value="fair"/>
                                                <xs:enumeration value="regular"/>
                                                <xs:enumeration value="low"/>
                                                <xs:enumeration value="trickle"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="lock" default="false" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Bandwidth Policy Lock. Type: boolean (true|false). After an outgoing transfer is started, its Policy may be modified in real time. The default setting of false gives users the ability to adjust the transfer's Policy. A setting of true prevents real-time modification of the Policy.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="allowed" default="any" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Bandwidth Policy Allowed. The value chosen sets the allowed Bandwidth Policy for outgoing transfers. Aspera transfers use fixed, high, fair and low policies to accommodate network-sharing requirements. When set to any, the server will not deny any transfer based on policy setting. When set to high, transfers with a Policy of high and less aggressive transfer policies (e.g. fair or low) will be permitted. Fixed transfers will be denied. When set to low, only transfers with a Bandwidth Policy of low will be allowed.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="any"/>
                                                <xs:enumeration value="high"/>
                                                <xs:enumeration value="fair"/>
                                                <xs:enumeration value="regular"/>
                                                <xs:enumeration value="low"/>
                                                <xs:enumeration value="trickle"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="priority" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="cap" default="high" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_out_bandwidth_flow_priority_cap.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="high"/>
                                                <xs:enumeration value="normal"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="default" default="normal" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_out_bandwidth_flow_priority_default.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="high"/>
                                                <xs:enumeration value="normal"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="lock" default="false" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_out_bandwidth_flow_priority_lock. Type: boolean (true|false).</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="aggressiveness" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="cap" type="xs:string" default="0" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_out_bandwidth_flow_aggressiveness_cap. Type: float.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="default" type="xs:string" default="0" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_out_bandwidth_flow_aggressiveness_default. Type: float.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                    <xs:element name="network_rc" minOccurs="1">
                                      <xs:complexType>
                                        <xs:all>
                                          <xs:element name="module" default="delay" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_out_bandwidth_flow_network_rc_module.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="delay"/>
                                                <xs:enumeration value="delay-odp"/>
                                                <xs:enumeration value="delay-adv"/>
                                                <xs:enumeration value="delay-laq"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="tcp_friendly" default="false" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>transfer_out_bandwidth_flow_network_rc_tcp_friendly. Type: boolean (true|false).</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="true"/>
                                                <xs:enumeration value="false"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="predictor" default="unset" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Traffic RTT Predictor. The predictor is designed to compensate for feedback signal delay due to RTT measurement itself. Numerical prediction methods include none|alphabeta|bezier|ets|fd31, none is the default.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="unset"/>
                                                <xs:enumeration value="none"/>
                                                <xs:enumeration value="alphabeta"/>
                                                <xs:enumeration value="fd31"/>
                                                <xs:enumeration value="bezier"/>
                                                <xs:enumeration value="ets"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                          <xs:element name="predictor_range" type="xs:string" default="2" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Rate Control Predictor Range. Type: float. The range of prediction, as a factor of the current sRTT. For example, the default value is 2.0, which means the predictor estimates the instantaneous network RTT that is 2.0*sRTT in the future. A higher value makes the rate-controller more sensitive to RTT changes, but also more vulnerable to RTT noise.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="predictor_limit_range" type="xs:string" default="3" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Rate Control Predictor Limit Range. Type: float. A limit function parameter that prevents the predictor from overpredicting. predictor_range &lt; prediction_limit_range. The default value is 3.0.</xs:documentation>
                                            </xs:annotation>
                                          </xs:element>
                                          <xs:element name="target_queue" default="unset" minOccurs="1">
                                            <xs:annotation>
                                              <xs:documentation>Outgoing Rate Control Target Queue. Available options are static|dynamic. Static is the default target queueing scheme and is based on estimated bandwidth. Dynamic is a target queueing scheme based on estimated RTT noise level and propagation delay. Dynamic mode is designed to work with the RTT predictor so that the rate controller can reach equilibrium quickly.</xs:documentation>
                                            </xs:annotation>
                                            <xs:simpleType>
                                              <xs:restriction base="xs:string">
                                                <xs:enumeration value="unset"/>
                                                <xs:enumeration value="static"/>
                                                <xs:enumeration value="dynamic"/>
                                              </xs:restriction>
                                            </xs:simpleType>
                                          </xs:element>
                                        </xs:all>
                                      </xs:complexType>
                                    </xs:element>
                                  </xs:all>
                                </xs:complexType>
                              </xs:element>
                            </xs:all>
                          </xs:complexType>
                        </xs:element>
                      </xs:all>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="encryption" minOccurs="1">
                    <xs:complexType>
                      <xs:all>
                        <xs:element name="user_value" type="xs:string" default="any" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>range_test. Type: Range of values. Preset display values: any, none, aes-128, aes-192, aes-256, aes-128-cfb, aes-192-cfb, aes-256-cfb, aes-128-gcm, aes-192-gcm or aes-256-gcm.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="allowed_cipher" default="any" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Encryption Allowed. Describes the type of transfer encryption accepted by this computer. When set to any the computer allows both encrypted and non-encrypted transfers. When set to none the computer restricts transfers to non-encrypted transfers only. When set to an aes type, the computer restricts transfers to encrypted transfers only.</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="any"/>
                              <xs:enumeration value="none"/>
                              <xs:enumeration value="aes-128"/>
                              <xs:enumeration value="aes-192"/>
                              <xs:enumeration value="aes-256"/>
                              <xs:enumeration value="aes-128-cfb"/>
                              <xs:enumeration value="aes-192-cfb"/>
                              <xs:enumeration value="aes-256-cfb"/>
                              <xs:enumeration value="aes-128-gcm"/>
                              <xs:enumeration value="aes-192-gcm"/>
                              <xs:enumeration value="aes-256-gcm"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="strict_allowed_cipher" default="true" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Strict Encryption Allowed. Type: boolean (true|false). Set to true where allowed cipher is a strict requirement. When false, cipher fallback to legacy cipher is allowed.</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="fips_mode" default="no" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Do encrypted transfers in FIPS 140-2 certified encryption mode. Set to 'enabled' when FIPS conformance is needed on the node. When set to 'enabled', encrypted transfers use a FIPS 140-2 certified encryption module, and transfer start is delayed while module checksums are verified. All ciphers and hash algorithms that are not FIPS compliant will abort transfers. When set to 'disabled`, FIPS mode will be disabled on the node. When set to 'required', both the client and server will be required to use a FIPS 140-2 certified encryption module for transfers.</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="no"/>
                              <xs:enumeration value="false"/>
                              <xs:enumeration value="disabled"/>
                              <xs:enumeration value="yes"/>
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="enabled"/>
                              <xs:enumeration value="required"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="byok_enabled" default="false" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_encryption_byok_enabled. Type: boolean (true|false).</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="content_protection_required" default="false" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Type: boolean (true|false). Set to true to require that content be left encrypted at the destination. Use this option when all content uploaded to this server must be stored on disk as secure envelopes.</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="content_protection_secret" type="xs:string" minOccurs="0">
                          <xs:annotation>
                            <xs:documentation>Type: string. A passphrase used, if the client does not provide one and content protection is required, to encrypt files uploaded to, or to decrypt files downloaded from, this server.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="content_protection_strong_pass_required" default="false" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Strong Password Required for Content Encryption. Type: boolean (true|false). Set to true to require strong passphrase for content protection (6 characters long, containing at least one letter, number and special symbol).</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="extension" type="xs:string" default=".aspera-env" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_encryption_content_protection_extension. Type: string.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                      </xs:all>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="protocol_options" minOccurs="1">
                    <xs:complexType>
                      <xs:all>
                        <xs:element name="bind_ip_address" type="xs:string" minOccurs="0">
                          <xs:annotation>
                            <xs:documentation>Type: string. Specify an IP address for the server to bind its UDP connection. If a valid IP address is given, the server sends and receives UDP packets ONLY on the interface corresponding to that IP address</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="server_ip_address" type="xs:string" minOccurs="0">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_server_ip_address. Type: string.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="bind_udp_port" type="xs:string" default="33001" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Type: uint32. Range: 1-65535 Specify a port number for the server to bind its UDP connection. Valid port numbers range between 1 and 65535.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="udp_port_reuse" default="true" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Server UDP Port reuse. Type: boolean (true|false). When set to true, allow different processes to reuse the same UDP port at the server. The default setting is true.</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="disable_batching" default="false" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Disable Packet Batching. Type: boolean (true|false). When set to true, send UDP datagrams individually, not in batches. This results in smoother data traffic at a cost of higher CPU usage.</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="batch_size" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_batch_size. Type: uint32.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="sessini_optimization" default="false" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_sessini_optimization. Type: boolean (true|false).</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="max_sock_buffer" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Maximum Socket Buffer (bytes). Type: uint32. Sets an upper bound for the UDP socket buffer size. A larger buffer will result in a faster and/or more stable transfer; however, more memory will be utilized. The default of 0 will cause the Aspera session to use its default internal buffer size because the attribute could be applied on either sender or receiver.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="min_sock_buffer" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Minimum Socket Buffer (bytes). Type: uint32. Set the minimum UDP socket buffer size for an Aspera transfer.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="datagram_size" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_datagram_size. Type: uint32.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="rate_instru_type" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_rate_instru_type. Type: uint32.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="rtt_autocorrect" default="true" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>RTT Auto-Correction. Type: boolean (true|false). Enable auto-correction of base (minimum) RTT measurement. The default setting is false. This feature is helpful for maintaining accurate transfer rates in hypervisor-based virtual environments.</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="rtt_histlen" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_rtt_histlen. Type: uint32.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="rtt_variation_index" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_rtt_variation_index. Type: float.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="rtt_estimate_skew" default="false" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_rtt_estimate_skew. Type: boolean (true|false).</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="rtt_reverse_infer" default="true" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>Reverse Path Congestion Inference. Type: boolean (true|false). Enable reverse path congestion inference. The default setting of true prevents the transfer speed of a session from being adversely affected by congestion in the reverse (non data-sending) transfer direction. This feature is useful for boosting speed in bi-directional transfers.</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="rtt_show_dist_on_congestion" default="true" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_rtt_show_dist_on_congestion. Type: boolean (true|false).</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="rex_table_size" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_rex_table_size. Type: uint32.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="rex_timer_size" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_rex_timer_size. Type: uint32.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="chunk_size" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>transfer_protocol_options_chunk_size. Type: uint32.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                      </xs:all>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="log_files_activity" default="true" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>transfer_log_files_activity. Type: boolean (true|false).</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="true"/>
                        <xs:enumeration value="false"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="log_stats_interval" type="xs:string" default="20" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>transfer_log_stats_interval. Type: uint32.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="validation_file_start" default="none" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Run File Validation at File Start. none - No validation to be performed uri - Validate using an external URI</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="none"/>
                        <xs:enumeration value="uri"/>
                        <xs:enumeration value="external"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="validation_file_stop" default="none" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Run File Validation at File Stop. none - No validation to be performed uri - Validate using an external URI post_transfer - Validate after the transfer, before reporting the file complete</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="none"/>
                        <xs:enumeration value="uri"/>
                        <xs:enumeration value="external"/>
                        <xs:enumeration value="post_transfer"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="validation_session_start" default="none" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Run File Validation at Session Start. none - No validation to be performed uri - Validate using an external URI</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="none"/>
                        <xs:enumeration value="uri"/>
                        <xs:enumeration value="external"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="validation_session_stop" default="none" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Run File Validation at Session Stop. none - No validation to be performed uri - Validate using an external URI</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="none"/>
                        <xs:enumeration value="uri"/>
                        <xs:enumeration value="external"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="validation_threshold" default="none" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Run File Validation When Crossing File Threshold. none - No validation to be performed uri - Validate using an external URI</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="none"/>
                        <xs:enumeration value="uri"/>
                        <xs:enumeration value="external"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="validation_uri" type="xs:string" minOccurs="0">
                    <xs:annotation>
                      <xs:documentation>Type: string.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="validation_threshold_kb" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: uint32.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="validation_threads" type="xs:string" default="5" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: uint32.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="validation_secure" default="false" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: boolean (true|false).</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="true"/>
                        <xs:enumeration value="false"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="lua_session_start_script_base64" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Base64-Encoded Lua Script for Session Start. Type: string. Base64 encoded lua script, ignored if lua_session_start_script_path is defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="lua_session_start_script_path" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>File Path to Lua Script for Session Start. Type: string. File path to lua script, overrides lua_session_start_script_base64 if defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="lua_session_stop_script_base64" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Base64-Encoded Lua Script for Session Stop. Type: string. Base64 encoded lua script, ignored if lua_session_stop_script_path is defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="lua_session_stop_script_path" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>File Path to Lua Script for Session Stop. Type: string. File path to lua script, overrides lua_session_stop_script_base64 if defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="lua_file_start_script_base64" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Base64-Encoded Lua Script for File Start. Type: string. Base64 encoded lua script, ignored if lua_file_start_script_path is defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="lua_file_start_script_path" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>File Path to Lua Script for File Start. Type: string. File path to lua script, overrides lua_file_start_script_base64 if defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="lua_session_progress_script_base64" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Base64-Encoded Lua Script for Session Progress. Type: string. Base64 encoded lua script, ignored if lua_session_progress_script_path is defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="lua_session_progress_script_path" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>File Path to Lua Script for Session Progress. Type: string. File path to lua script, overrides lua_session_progress_script_base64 if defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="lua_file_stop_script_base64" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Base64-Encoded Lua Script for File Stop. Type: string. Base64 encoded lua script, ignored if lua_file_stop_script_path is defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="lua_file_stop_script_path" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>File Path to Lua Script for File Stop. Type: string. File path to lua script, overrides lua_file_stop_script_base64 if defined</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="multi_session_threshold_default" type="xs:string" default="-1" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: int64. Set the multi_session_threshold_default in bytes. The default setting of -1 is used to denote that the configuration file does not specify a multi-session threshold default. A setting of 0 disables multi-session transfers. A setting greater than 0 will enable multi-session transfer for files greater-than or equal-to the specified threshold.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="multi_session_enabled" default="true" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Enable Multi-session transfers. Type: boolean (true|false). Set to False to disable multi-session transfers (attempts will result in an error)</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="true"/>
                        <xs:enumeration value="false"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="chunker_max_mem" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: uint64.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                </xs:all>
              </xs:complexType>
            </xs:element>
            <xs:element name="file_system" minOccurs="1" maxOccurs="unbounded">
              <xs:complexType>
                <xs:all>
                  <xs:element name="file_create_mode" type="xs:string" default="Undefined" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: octal string. Preset display values: Undefined. Specify file creation mode (permissions). If specified, create files with these permissions (for example 0755), irrespective of File Create Grant Mask and permissions of the file on the source computer. Does not apply to Windows.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="file_create_grant_mask" type="xs:string" default="644" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: octal string. Preset display values: Undefined. Used to determine mode for newly created files if File Create Mode is not specified. If specified, file modes will be set to their original modes plus the Grant Mask values. Only takes effect when File Create Mode is not specified. Does not apply to Windows.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="directory_create_mode" type="xs:string" default="Undefined" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: octal string. Preset display values: Undefined. Specify directory creation mode (permissions). If specified, create directories with these permissions irrespective of Directory Create Grant Mask and permissions of the directory on the source computer. Does not apply to Windows.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="directory_create_grant_mask" type="xs:string" default="755" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: octal string. Preset display values: Undefined. Used to determine mode for newly created directories if Directory Create Mode is not specified. If specified, directory modes will be set to their original modes plus the Grant Mask values. Only takes effect when Directory Create Mode is not specified. Does not apply to Windows.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="read_block_size" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Read Block Size (bytes). Type: uint64. This is a performance tuning parameter for an Aspera sender. It represents the number of bytes an Aspera sender reads at a time from the source disk drive. Only takes effect when server is sender. If not set by server configuration, takes value from client command line parameter, if present, otherwise set to 0. The default of 0 will cause the Aspera sender to use its default internal buffer size, which may be different for different operating systems.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="write_block_size" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Write Block Size (bytes). Type: uint64. This is a performance tuning parameter for an Aspera receiver. Number of bytes an Aspera receiver writes data at a time onto disk drive. Only takes effect when server is receiver. If not set by server configuration, takes value from client command line parameter, if present, otherwise set to 0. The default of 0 will cause the Aspera receiver to use its default internal buffer size, which may be different for different operating systems.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="read_threads" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Number of I/O Read Threads. Type: uint64. This is a performance tuning parameter for an Aspera sender. It represents the number of threads the Aspera sender will use to read file contents from the source disk drive. It takes effect on both client and server, when acting as a sender. The default of 0 will cause the Aspera sender to use its internal default, which may be different for different platforms.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="write_threads" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Number of I/O Write Threads. Type: uint64. This is a performance tuning parameter for an Aspera receiver. It represents the number of threads the Aspera receiver will use to write out file contents to the destination disk drive. It takes effect on both client and server, when acting as a receiver. The default of 0 will cause the Aspera receiver to use its internal default, which may be different for different platforms.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="scan_threads" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Number of Dir Scanning Threads. Type: uint64. This is a performance tuning parameter for an Aspera sender. It represents the number of threads the Aspera sender will use to scan directory contents. It takes effect on both client and server, when acting as a sender. The default of 0 will cause the Aspera sender to use its internal default, which may be different for different platforms.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="meta_threads" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Number of Metadata Threads. Type: uint64. This is a performance tuning parameter for an Aspera receiver. It represents the number of threads the Aspera receiver will use to create directories or zero file sizes. It takes effect on both client and server, when acting as a receiver. The default of 0 will cause the Aspera receiver to use its internal default, which may be different for different platforms.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="worker_threads" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Number of Worker Threads. Type: uint64. This is a performance tuning parameter for an Aspera sender/receiver. It represents the number of threads the Aspera sender/receiver will use to delete files/directories. It takes effect on both client and server. The default of 0 will cause the Aspera sender/receiver to use its internal default, which may be different for different platforms.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="sparse_file" default="false" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Sparse File Checking. Type: boolean (true|false). This is a performance tuning parameter for an Aspera receiver. It represents sparse file checking the Aspera receiver will do to avoid writing extra zero blocks. It takes effect on both client and server, when acting as a receiver. The default of 0 will cause the Aspera receiver to write all the blocks, and a value of 1 cause the Aspera receiver to avoid writing zero blocks and save disk space.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="true"/>
                        <xs:enumeration value="false"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="fail_on_attr_error" default="yes" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Behavior on Attr Error. Set behavior for when operations on files attempt to set or change file attributes (such as POSIX ownership, ACLs, or modification time) and fail. Setting to yes (default) returns an error and causes the operation to fail. Setting to no logs the error and the operation continues.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="no"/>
                        <xs:enumeration value="yes"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="compression_method" default="lz4" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Compression Method for File Transfer. This is a performance tuning parameter for an Aspera sender/receiver available since transfer engine version 4. It represents the compression method the Aspera agent will use to reduce the size of transferred data. It takes effect on both client and server. The default value (lz4) will cause sender and receiver to use the lz4 compression algorithm.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="none"/>
                        <xs:enumeration value="qlz"/>
                        <xs:enumeration value="zlib"/>
                        <xs:enumeration value="lz4"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="use_file_cache" default="true" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: boolean (true|false). This is a performance tuning parameter for an Aspera receiver. Enable or disable per-file memory caching at the data receiver. File level memory caching improves data write speed on Windows platforms in particular, but will use more memory. We suggest using a file cache on systems that are transferring data at speeds close to the performance of their storage device, and disabling it for systems with very high concurrency (because memory utilization will grow with the number of concurrent transfers).</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="true"/>
                        <xs:enumeration value="false"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="max_file_cache_buffer" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Max File Cache Buffer (bytes). Type: uint64. This is a performance tuning parameter for an Aspera receiver. This value corresponds to the maximal size allocated for per-file memory cache (see Use File Cache). The default of 0 will cause the Aspera receiver to use its internal buffer size, which may be different for different operating systems.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="ring_buf_units" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: uint32.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="ring_buf_max_size" type="xs:string" default="0" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: uint32.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="resume_suffix" type="xs:string" default=".aspx" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: string. Extension name of a class of special files holding meta data information of regular data files. Useful in the context of resuming partially completed transfers. During resume mode (-k1/2/3), each data file has a corresponding metadata file with the same name and the pre-specified resume suffix.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="symbolic_links" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Symbolic Link Actions. Action(s) to be taken upon encountering a symbolic link on the server side Which action to take depends on both the platform and the particular application context. The (combination of) choices are logically or'ed before use. For instance, use none alone to mean skip, and shut out other choices; when both follow and follow_wide are present, the latter is recognized.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="none"/>
                        <xs:enumeration value="create"/>
                        <xs:enumeration value="follow"/>
                        <xs:enumeration value="follow_wide"/>
                        <xs:enumeration value="any combination of the aforementioned delimited by comma"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="mgmt_portfile_dir" type="xs:string" minOccurs="0">
                    <xs:annotation>
                      <xs:documentation>Type: string.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="mgmt_port_connect_timeout_usec" type="xs:string" default="5000000" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: uint64.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="preserve_attributes" default="use client setting" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Configure file creation policy. When set to none, do not preserve the timestamp of source files. When set to times, preserve the timestamp of the source files at destination.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="use client setting"/>
                        <xs:enumeration value="none"/>
                        <xs:enumeration value="times"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="preserve_acls" type="xs:string" minOccurs="0">
                    <xs:annotation>
                      <xs:documentation>Type: string.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="preserve_xattrs" type="xs:string" minOccurs="0">
                    <xs:annotation>
                      <xs:documentation>Type: string.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="preserve_attributes_pvcl_read" default="disable" minOccurs="1">
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="disable"/>
                        <xs:enumeration value="enable"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="preserve_attributes_pvcl_write" default="disable" minOccurs="1">
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="disable"/>
                        <xs:enumeration value="enable"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="overwrite" default="allow" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Overwrite is an Aspera server setting that determines whether Aspera clients are allowed to overwrite files on the server. By default it is set to allow, meaning that clients uploading files to the servers will be allowed to overwrite existing files as long as file permissions allow that action. If set to deny, clients uploading files to the server will not be able to overwrite existing files, regardless of file permissions.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="allow"/>
                        <xs:enumeration value="deny"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="file_manifest" type="xs:string" default="none" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Type: string. Choices: text, none, disable Description if empty: &lt;None&gt; When set to text a text file &quot;receipt&quot; of all files within each transfer session is generated. If set to disable no File Manifest is created. The file manifest is a file containing a list of everything that was transferred in a given transfer session. The filename of the File Manifest itself is automatically generated based on the transfer session's unique ID. The location where each manifest is written is specified by the File Manifest Path value. If no File Manifest Path is specified, the file will be generated under the destination path at the receiver, and under the first source path at the sender.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="file_manifest_path" type="xs:string" minOccurs="0">
                    <xs:annotation>
                      <xs:documentation>Type: string. The location where the manifest file is created (see File Manifest)</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="file_manifest_inprogress_suffix" type="xs:string" default=".aspera-inprogress" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>File Manifest Suffix. Type: string. The suffix of the manifest file when transfer is ongoing (see File Manifest)</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="pre_calculate_job_size" default="any" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Configure the policy of calculating total job size before data transfer. If set to any, follow client configurations (-o PreCalculateJobSize). If set to no, disable calculating job size before transferring. If set to yes, enable calculating job size before transferring.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="any"/>
                        <xs:enumeration value="no"/>
                        <xs:enumeration value="yes"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="replace_illegal_chars" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Convert Restricted Filesystem Characters. Type: string. Enable replacement of reserved characters in file and directory names with a non-reserved character. The first character is the replacement character and subsequent characters in the string are what is to be replaced. On Windows, the character list is predefined so this option is only the replacement character. Disabled by default, the setting only applies to files written to the local file system. To enable on the peer, must be set in the peer's configuration file.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="storage_rc" minOccurs="1">
                    <xs:complexType>
                      <xs:all>
                        <xs:element name="adaptive" default="true" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>storage_rc_adaptive. Type: boolean (true|false).</xs:documentation>
                          </xs:annotation>
                          <xs:simpleType>
                            <xs:restriction base="xs:string">
                              <xs:enumeration value="true"/>
                              <xs:enumeration value="false"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                        <xs:element name="buf_min" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>storage_rc_buf_min. Type: float.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="buf_target" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>storage_rc_buf_target. Type: float.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="buf_delta" type="xs:string" default="0" minOccurs="1">
                          <xs:annotation>
                            <xs:documentation>storage_rc_buf_delta. Type: float.</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                      </xs:all>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="filters" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>File Filter Pattern List. Type: Set of string values. XML separator: &lt;filter&gt; Include/Exclude files or directories with the specified pattern in the transfer. Add multiple entries for more inclusion/exclusion patterns. To specify an inclusion, add '+ ' (+ and whitespace) at the beginning of the pattern. To specify an exclusion, add '- ' (- and whitespace) at the beginning of the pattern. Two symbols can be used in the setting of patterns: * (Asterisk) Represents zero to many characters in a string, for example, *.tmp matches .tmp and abcde.tmp. ? (Question Mark) Represents one character, for example, t?p matches tmp but not temp.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="partial_file_suffix" type="xs:string" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Partial File Name Suffix. Type: string. Extension to be added to the names of files that are currently only partially transferred.</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="file_checksum" default="any" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>File Checksum Method. Type of checksum to compute while reading file, sent along with the file and logged via management message, manifest, and/or pre/post script. It may be used to verify that file contents on the destination match what was read at the source.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:enumeration value="any"/>
                        <xs:enumeration value="md5"/>
                        <xs:enumeration value="sha1"/>
                        <xs:enumeration value="sha256"/>
                        <xs:enumeration value="sha384"/>
                        <xs:enumeration value="sha512"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="file_checksum_cache" default="false" minOccurs="1">
                    <xs:annotation>
                      <xs:documentation>Enable File Checksum Caching. Type: boolean (true|false). In the event file checksum is enabled, maintain a cache of partial checksum values as it is calculated. If the transfer is interrupted, use these partial checksum values to resume the checksum calculation from where the transfer was interrupted.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
